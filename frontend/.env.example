# API Configuration
# Set the backend API URL. Use relative path '/' for same-domain deployment
# or full URL 'http://localhost:3001' for separate backend during development
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mock Data (Development Only)
# Set to 'true' to use mock data instead of real API calls
NEXT_PUBLIC_USE_MOCKS=false

# Analytics Providers (Optional)
NEXT_PUBLIC_ANALYTICS_PROVIDER=ga
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token
